{
  "name": "web-clipboard",
  "version": "2.0.0",
  "description": "多设备实时同步剪贴板 - WebSocket 版本",
  "main": "server.js",
  "bin": {
    "web-clipboard-win": "client-windows-interactive.js"
  },
  "scripts": {
    "start": "node server-local.js",
    "start:local": "node server-local.js",
    "start:remote": "node server-remote.js",
    "client:mac": "node start-connect-remote.js",
    "client:windows": "node client-windows.js",
    "dev:local": "nodemon server-local.js",
    "dev:remote": "nodemon server-remote.js",
    "pkg:build": "pkg client-windows-interactive.js --targets node22-win-x64 --output dist/web-clipboard-win.exe",
    "pkg:clean": "rm -rf dist"
  },
  "keywords": [
    "clipboard",
    "websocket",
    "sync",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  }
}
