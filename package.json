{
  "name": "web-clipboard",
  "version": "2.0.0",
  "type": "module",
  "description": "多设备实时同步剪贴板 - WebSocket 版本",
  "main": "interactive.js",
  "bin": {
    "web-clipboard": "interactive.js"
  },
  "scripts": {
    "start": "node server-local.js",
    "start:local": "node server-local.js",
    "start:remote": "node server-remote.js",
    "client:mac": "node start-connect-remote.js",
    "client:windows": "node client-windows.js",
    "dev:local": "nodemon server-local.js",
    "dev:remote": "nodemon server-remote.js",
    "pkg:build:win": "pkg . --targets node18-win-x64 --output release-build/pkg/win/web-clipboard.exe",
    "pkg:build:mac_x64": "pkg . --targets node18-macos-x64 --output release-build/pkg/mac/web-clipboard-x64",
    "pkg:build:mac_arm64": "pkg . --targets node18-macos-arm64 --output release-build/pkg/mac/web-clipboard-arm64",
    "pkg:build:linux": "pkg . --targets node18-linux-x64 --output release-build/pkg/linux/web-clipboard",
    "pkg:build:all": "npm run pkg:build:win && npm run pkg:build:mac_x64 && npm run pkg:build:mac_arm64 && npm run pkg:build:linux",
    "pkg:clean": "rm -rf release-build/pkg"
  },
  "keywords": [
    "clipboard",
    "websocket",
    "sync",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "clipboardy": "^5.3.1",
    "execa": "^9.6.1",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "interactive.js",
      "utils.js"
    ],
    "assets": [
      "node_modules/clipboardy/**/*",
      "node_modules/execa/**/*",
      "node_modules/ws/**/*"
    ],
    "outputPath": "release-build/pkg",
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-linux-x64"
    ]
  }
}
