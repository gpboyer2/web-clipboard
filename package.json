{
  "name": "web-clipboard",
  "version": "2.0.0",
  "type": "module",
  "description": "多设备实时同步剪贴板 - WebSocket 版本",
  "main": "interactive.js",
  "bin": {
    "web-clipboard": "interactive.js"
  },
  "scripts": {
    "start": "node server-local.js",
    "start:local": "node server-local.js",
    "start:remote": "node server-remote.js",
    "client:mac": "node start-connect-remote.js",
    "client:windows": "node client-windows.js",
    "dev:local": "nodemon server-local.js",
    "dev:remote": "nodemon server-remote.js",
    "nexe:build:win": "nexe --build --target windows-x64-18.18.2 --output release-build/nexe/win/web-clipboard.exe",
    "nexe:build:mac_x64": "nexe --build --target macos-x64-18.18.2 --output release-build/nexe/mac/web-clipboard-x64",
    "nexe:build:mac_arm64": "nexe --build --target macos-arm64-18.18.2 --output release-build/nexe/mac/web-clipboard-arm64",
    "nexe:build:linux": "nexe --build --target linux-x64-18.18.2 --output release-build/nexe/linux/web-clipboard",
    "nexe:build:all": "npm run nexe:build:win && npm run nexe:build:mac_x64 && npm run nexe:build:mac_arm64 && npm run nexe:build:linux",
    "nexe:clean": "rm -rf release-build/nexe"
  },
  "keywords": [
    "clipboard",
    "websocket",
    "sync",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "clipboardy": "^5.3.1",
    "execa": "^9.6.1",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "nexe": "^5.0.0-beta.4"
  }
}
